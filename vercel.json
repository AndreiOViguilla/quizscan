{
  "version": 2,
  "builds": [
    {
      "src": "api/transcript.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    { "src": "/api/transcript", "dest": "/api/transcript.py" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
